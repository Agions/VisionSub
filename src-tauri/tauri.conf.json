{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HardSubX",
  "version": "3.2.0",
  "identifier": "com.hardsubx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devtools": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HardSubX — Professional Video Subtitle Extraction",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; connect-src 'self' ipc: tauri:; font-src 'self' data:; worker-src 'self' blob:; frame-src 'self' blob:; media-src 'self' asset: blob: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "appimage", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "category": "Utility",
    "shortDescription": "Professional video subtitle extraction tool",
    "longDescription": "HardSubX is a professional video subtitle extraction tool powered by OCR. It extracts hardcoded subtitles from videos using Tesseract.js, PaddleOCR, or EasyOCR, and exports to multiple formats including SRT, VTT, ASS, SSA, JSON, TXT, LRC, SBV, and CSV.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
